{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "A cat owner",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["name"]
    },
    "Cat": {
      "title": "Cat",
      "description": "A cat",
      "type": "object",
      "properties": {
        "owner_id": { "type": "string" },
        "name": { "type": "string" },
        "species": { "type": "string" },
        "breed": { "type": "string" },
        "color": { "type": "string" },
        "chip_number": { "type": "string" },
        "vaccine_tc_date": { "type": "string" },
        "vaccine_l_date": { "type": "string" },
        "parasite_treatment_date": { "type": "string" },
        "birth_date": { "type": "string" },
        "age": { "type": "string" }
      },
      "required": ["owner_id", "name"]
    },
    "Stay": {
      "title": "Stay",
      "description": "A cat's stay in the hotel",
      "type": "object",
      "properties": {
        "cat_id": { "type": "string" },
        "box_number": { "type": "number" },
        "arrival_date": { "type": "string" },
        "planned_departure": { "type": "string" },
        "actual_departure": { "type": "string" },
        "comments": { "type": "string" },
        "contract_scan_url": { "type": "string" }
      },
      "required": ["cat_id", "box_number", "arrival_date", "planned_departure"]
    },
    "HealthLog": {
      "title": "Health Log",
      "description": "Health tracking for a stay",
      "type": "object",
      "properties": {
        "stay_id": { "type": "string" },
        "date": { "type": "string" },
        "ate_well": { "type": "boolean" },
        "abnormal_behavior": { "type": "boolean" },
        "medication": { "type": "string" },
        "incident": { "type": "string" },
        "comments": { "type": "string" }
      },
      "required": ["stay_id", "date"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice for a stay",
      "type": "object",
      "properties": {
        "stay_id": { "type": "string" },
        "amount": { "type": "number" },
        "service_type": { "type": "string" },
        "created_at": { "type": "string" },
        "invoice_number": { "type": "string" },
        "type": { "type": "string", "enum": ["standard", "deposit", "final"] },
        "status": { "type": "string" },
        "payment_method": { "type": "string" },
        "deposit_amount": { "type": "number" },
        "reference_total": { "type": "number" },
        "related_invoice_number": { "type": "string" },
        "arrival_date": { "type": "string" },
        "departure_date": { "type": "string" },
        "owner_name": { "type": "string" },
        "cat_name": { "type": "string" }
      },
      "required": ["stay_id", "amount", "invoice_number", "status"]
    },
    "Media": {
      "title": "Media",
      "description": "Images or videos for a stay",
      "type": "object",
      "properties": {
        "stay_id": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "url": { "type": "string" },
        "filename": { "type": "string" }
      },
      "required": ["stay_id", "type", "url", "filename"]
    },
    "SystemSetting": {
      "title": "Setting",
      "description": "App settings",
      "type": "object",
      "properties": {
        "value": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Store clients"
    },
    "/cats/{catId}": {
      "schema": "Cat",
      "description": "Store cats"
    },
    "/stays/{stayId}": {
      "schema": "Stay",
      "description": "Store hotel stays"
    },
    "/health_logs/{logId}": {
      "schema": "HealthLog",
      "description": "Store health logs"
    },
    "invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Store invoices"
    },
    "media/{mediaId}": {
      "schema": "Media",
      "description": "Store media items"
    },
    "/settings/{settingKey}": {
      "schema": "SystemSetting",
      "description": "Store settings like logo"
    }
  }
}
